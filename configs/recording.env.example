# CAN 포트
# leader: 사람이 손으로 움직이는 마스터 팔
# follower: 실제 동작을 수행하는 슬레이브 팔
# piper-setup으로 이름을 바꾼 경우 can_leader1/can_follower1을 쓰고,
# 이름 변경 전이면 can0/can1처럼 실제 인터페이스명 입력
LEADER_PORT=can_leader1
FOLLOWER_PORT=can_follower1
BITRATE=1000000

# 선택: USB 물리 포트별로 CAN 이름을 고정하고 싶을 때 사용
# 값은 `sudo ethtool -i can0 | grep bus-info`로 확인
# 비워두면 1__init_can.sh는 LEADER_PORT/FOLLOWER_PORT 이름의 기존 인터페이스만 초기화
LEADER_USB_BUS=
FOLLOWER_USB_BUS=
IGNORE_CHECK=false

# LeRobot metadata에 기록될 robot ID
# 같은 실험 장비에서는 ID 고정 권장
ROBOT_ID=piper_follower1
TELEOP_ID=piper_leader1

# 카메라 설정
# CAMERA_TYPE=opencv: TOP_CAM/WRIST_CAM은 scripts/tools/camera_check.py 또는 lerobot-find-cameras opencv로 확인한 index
# CAMERA_TYPE=intelrealsense: TOP_CAM/WRIST_CAM은 lerobot-find-cameras realsense로 확인한 serial_number 또는 name
# 카메라별로 섞어 쓰려면 TOP_CAM_TYPE/WRIST_CAM_TYPE에 opencv 또는 intelrealsense 지정
# TOP_CAM: 작업 공간 전체와 팔 움직임을 보는 상방 카메라
# WRIST_CAM: gripper와 조작 대상을 가까이 보는 팔목 카메라
CAMERA_TYPE=opencv
# TOP_CAM_TYPE=intelrealsense
# WRIST_CAM_TYPE=intelrealsense
TOP_CAM=0
WRIST_CAM=1
CAM_WIDTH=640
CAM_HEIGHT=480
FPS=30
REALSENSE_USE_DEPTH=false
REALSENSE_WARMUP_S=10.0
CAMERA_CONNECT_WARMUP=false
CAMERA_POST_CONNECT_WAIT_S=2.0
# TOP_REALSENSE_USE_DEPTH=false
# WRIST_REALSENSE_USE_DEPTH=false

# 데이터셋
# DATASET_REPO_ID: owner/dataset_name 형식
# DATASET_ROOT: 새 데이터셋 폴더 자체
# TASK: 공백 포함 값이므로 반드시 따옴표 사용
HF_USER=your_hf_name
DATASET_REPO_ID=local/piper_pick_pen_sample
DATASET_ROOT=records/local/piper_pick_pen_sample
NUM_EPISODES=1
EPISODE_TIME_S=10
RESET_TIME_S=10
TASK="pick up the pen"
PUSH_TO_HUB=false
DISPLAY_DATA=true
RESUME=false

# 텔레옵 시작 자세 보정
# 기본은 시작 시 강제 parking 비활성화
# 처음에는 자동 offset report를 보고, 필요하면 USE_MANUAL_ACTION_OFFSET=true로 고정
PARK_ON_CONNECT=false
USE_ACTION_OFFSET=true
USE_MANUAL_ACTION_OFFSET=false
ACTION_OFFSET_WARMUP_S=1.5
ACTION_OFFSET_REPORT_THRESHOLD=3.0
ACTION_OFFSET_JOINT1=0.0
ACTION_OFFSET_JOINT2=0.0
ACTION_OFFSET_JOINT3=0.0
ACTION_OFFSET_JOINT4=0.0
ACTION_OFFSET_JOINT5=0.0
ACTION_OFFSET_JOINT6=0.0
ACTION_OFFSET_GRIPPER=0.0
MAX_RELATIVE_TARGET=5.0
DISABLE_TORQUE_ON_DISCONNECT=true

# 학습 설정: 7__train.sh
POLICY_TYPE=smolvla
POLICY_REPO_ID=
POLICY_PRETRAINED_PATH=
POLICY_DEVICE=cuda
OUTPUT_DIR=outputs/train/piper_smolvla
JOB_NAME=piper_smolvla
BATCH_SIZE=8
STEPS=5000
SAVE_FREQ=1000
EVAL_FREQ=0
WANDB_ENABLE=false
PUSH_POLICY_TO_HUB=false

# 비동기 추론 설정: 8__run_server.sh / 9__run_client.sh
# grpc/grpcio-tools가 설치된 환경에서만 사용
SERVER_HOST=127.0.0.1
SERVER_PORT=8088
PRETRAINED_NAME_OR_PATH=
ACTIONS_PER_CHUNK=50
CHUNK_SIZE_THRESHOLD=0.8
AGGREGATE_FN_NAME=average
